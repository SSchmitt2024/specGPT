# specGPT environment template.
#   cp .env.example .env  &&  edit values  &&  do NOT commit .env
# .env is gitignored; this file is the canonical list of supported settings.

# ── Auth (REQUIRED) ─────────────────────────────────────────────────────────
# Shared password gate. Plaintext goes here, gets hashed (scrypt) at startup,
# and is wiped from process env before the first request lands.
APP_PASSWORD=change-me-to-a-real-password

# HMAC key for signing session cookies. MUST be at least 16 bytes.
# Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Rotating this invalidates every outstanding session immediately.
SESSION_SECRET=change-me-32-bytes-of-random

# ── Pipeline backends (REQUIRED) ────────────────────────────────────────────
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_KEY=your-supabase-anon-key
VOYAGE_API_KEY=your-voyage-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# ── Classifier LLM (REQUIRED — pick one provider) ───────────────────────────
LLM_PROVIDER=gemini   # or "openai"
GEMINI_API_KEY=your-gemini-api-key
# OPENAI_API_KEY=your-openai-api-key

# ── Optional ────────────────────────────────────────────────────────────────
# Include full pipeline trace in /api/query responses. Leaks chunk previews,
# model names, and timings — leave OFF in shared deployments.
# DEBUG_PIPELINE=0

# Server bind. Default 127.0.0.1 (loopback) so a debug build isn't accidentally
# exposed on the LAN. Set to 0.0.0.0 inside a container behind a reverse proxy.
# HOST=127.0.0.1
# PORT=8000

# Cookie security. Default ON (only sent over HTTPS). Set to 0 for local dev
# over plain HTTP, never in production.
# COOKIE_SECURE=1

# Trust X-Forwarded-For for the login throttle's per-IP key. Default OFF;
# only enable if you're behind a proxy that strips client-supplied headers
# (Railway, Cloudflare, etc.). Otherwise the throttle can be bypassed.
# TRUST_PROXY_HEADERS=0

# Logging.
# LOG_LEVEL=INFO

# Override LLM model defaults.
# LLM_MODEL=gemini-2.5-flash
